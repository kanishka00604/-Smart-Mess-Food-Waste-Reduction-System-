# Copy this file to .env and fill in your values

# MongoDB Connection (Local)
MONGO_URI=mongodb://localhost:27017/smart-mess

# OR MongoDB Atlas (Cloud) - replace with your actual URI
# MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/smart-mess

# JWT Secret - change this to a long random string in production
JWT_SECRET=supersecretjwtkey2025smartmess

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development
